erDiagram

    %% ════════════════════════════════════════════
    %% USER-SPECIFIC TABLES  (pri) = {prefix}_xxx
    %% ════════════════════════════════════════════

    pri_friend_log_current {
        text user_id PK
        text display_name
        text trust_level
        int  friend_number
    }

    pri_friend_log_history {
        int  id PK
        text created_at
        text type
        text user_id
        text display_name
        text previous_display_name
        text trust_level
        text previous_trust_level
        int  friend_number
    }

    pri_feed_gps {
        int  id PK
        text created_at
        text user_id
        text display_name
        text location
        text world_name
        text previous_location
        int  time
        text group_name
    }

    pri_feed_status {
        int  id PK
        text created_at
        text user_id
        text display_name
        text status
        text status_description
        text previous_status
        text previous_status_description
    }

    pri_feed_bio {
        int  id PK
        text created_at
        text user_id
        text display_name
        text bio
        text previous_bio
    }

    pri_feed_avatar {
        int  id PK
        text created_at
        text user_id
        text display_name
        text owner_id
        text avatar_name
        text current_avatar_image_url
        text current_avatar_thumbnail_image_url
    }

    pri_feed_online_offline {
        int  id PK
        text created_at
        text user_id
        text display_name
        text type
        text location
        text world_name
        int  time
        text group_name
    }

    pri_activity_sync_state_v2 {
        text user_id PK
        text updated_at
        int  is_self
        text source_last_created_at
        int  pending_session_start_at
        int  cached_range_days
    }

    pri_activity_sessions_v2 {
        int  session_id PK
        text user_id
        int  start_at
        int  end_at
        int  is_open_tail
        text source_revision
    }

    pri_activity_bucket_cache_v2 {
        text user_id PK
        text target_user_id PK
        int  range_days PK
        text view_kind PK
        text exclude_key PK
        text raw_buckets_json
        text normalized_buckets_json
        text summary_json
        text built_at
    }

    pri_notifications {
        text id PK
        text created_at
        text type
        text sender_user_id
        text sender_username
        text receiver_user_id
        text message
        text world_id
        text world_name
        int  expired
    }

    pri_notifications_v2 {
        text id PK
        text created_at
        text updated_at
        text expires_at
        text type
        text message
        text title
        int  seen
        text sender_user_id
        text sender_username
        text data
    }

    pri_moderation {
        text user_id PK
        text updated_at
        text display_name
        int  block
        int  mute
    }

    pri_avatar_history {
        text avatar_id PK
        text created_at
        int  time
    }

    pri_notes {
        text user_id PK
        text display_name
        text note
        text created_at
    }

    pri_mutual_graph_friends {
        text friend_id PK
    }

    pri_mutual_graph_links {
        text friend_id PK
